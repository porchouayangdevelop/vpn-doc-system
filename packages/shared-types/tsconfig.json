// packages/shared-types/tsconfig.json  ← ສຳລັບ type-check ແລະ IDE
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite":      true,
    "incremental":    true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "outDir":  "dist",
    "rootDir": "src",
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}