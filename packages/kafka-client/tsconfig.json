// packages/kafka-client/tsconfig.json  ← ສຳລັບ IDE + type-check
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite":       true,
    "incremental":     true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "outDir":          "dist",
    "rootDir":         "src",
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true,
    "paths": {
      "@vpndoc/shared-types": ["../shared-types/src"]
    }
  },
  "include":    ["src/**/*"],
  "exclude":    ["node_modules", "dist"],
  "references": [
    { "path": "../shared-types" }   // ← TS Project Reference
  ]
}